# ::id vi_amr_test_000931
# ::snt Trên Quảng trường Tahrir, nơi cộng đồng quốc tế liên tục lo sợ rằng những người Islam sẽ chiếm lấy cách mạng. Thực ra, họ tổ chức người Công giáo bảo vệ người Đạo Hồi, những người đang cầu nguyện, 1 đám cưới kiểu Coptic được hàng ngàn người Đạo Hồi chúc mừng.
# ::tok Trên Quảng_trường Tahrir , nơi cộng_đồng quốc_tế liên_tục lo_sợ rằng những người Islam sẽ chiếm lấy cách_mạng . Thực_ra , họ tổ_chức người Công_giáo bảo_vệ người Đạo_Hồi , những người đang cầu_nguyện , 1 đám_cưới kiểu Coptic được hàng ngàn người Đạo_Hồi chúc_mừng .
(m / multi-sentence
   :snt1 (b / be-located-at-91
            :ARG2 (q / quảng_trường
                     :name (n4 / name
                               :op1 "Tahrir"
                               :op2 "Square")
                     :location-of (l / lo_sợ
                                     :ARG0 (c / chiếm_lấy
                                              :ARG0 (n3 / người
                                                        :mod (r / religious-group
                                                                :name (n2 / name
                                                                          :op1 "Islamism")))
                                              :ARG1 (c2 / cách_mạng)
                                              :tense (s / sẽ))
                                     :ARG1 (c3 / cộng_đồng
                                               :mod (q2 / quốc_tế))
                                     :frequency (l2 / liên_tục))))
   :snt2 (t / tổ_chức
            :ARG0 (h / họ)
            :ARG1 (n7 / người
                      :ARG0-of (b2 / bảo_vệ
                                   :ARG1 (n8 / người
                                             :ARG0-of (c4 / cầu_nguyện
                                                          :tense (d2 / đang))
                                             :mod (r2 / religious-group
                                                      :name (n / name
                                                               :op1 "Muslim"))
                                             :snt3 (d / đám_cưới
                                                      :ARG1-of (c5 / chúc_mừng
                                                                   :ARG0 (n9 / người
                                                                             :quant (h2 / hàng_ngàn
                                                                                        :op1 1000)
                                                                             :mod r2))
                                                      :mod (e / ethnic-group
                                                              :name (n5 / name
                                                                        :op1 "Copt")))))
                      :mod (r3 / religious-group
                               :name (n6 / name
                                         :op1 "Christian")))
            :mod (t2 / thực_ra)))

