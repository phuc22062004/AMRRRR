# ::id vi_amr_test_000954
# ::snt Nếu chúng ta gập bề mặt lại hết lần này đến lần khác sau 16 lần lặp lại, 16 bước, chúng ta kết thúc với 400.000 bề mặt và hình dạng trông sẽ như thế này.
# ::tok Nếu chúng_ta gập bề_mặt lại hết lần này đến lần khác sau 16 lần lặp lại , 16 bước , chúng_ta kết_thúc với 400.000 bề_mặt và hình_dạng trông sẽ như thế_này .
(k / kết_thúc
   :ARG1 (c / chúng_ta)
   :ARG2 (c2 / có
             :ARG0 c
             :ARG1 (v / và
                      :op1 (b2 / bề_mặt
                               :quant 400000)
                      :op2 (h / hình_dạng
                              :ARG0-of (t / trông
                                          :tense (s2 / sẽ)
                                          :ARG0-of (v2 / ví_dụ)
                                          :ARG1 (n / này)))))
   :condition (a / and
                 :op1 (g / gập
                         :ARG0 c
                         :ARG1 (b / bề_mặt)
                         :frequency (l / lặp_lại_nhiều_lần))
                 :op2 (b3 / bước
                          :quant 16))
   :time (s / sau
            :op1 (l2 / lần_lặp
                     :quant 16)))

