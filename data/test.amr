# ::id vi_amr_test_000952
# ::snt Vì tôi đã thiết kế quá trình chứ không thiết kế các hình thể tôi có thể chạy quá trình ấy lặp lại nhiều lần để sản xuất ra những họ hình dạng khác nhau.
# ::tok Vì tôi đã thiết_kế quá_trình chứ không thiết_kế các hình_thể tôi có_thể chạy quá_trình ấy lặp lại nhiều lần để sản_xuất ra những họ hình_dạng khác nhau .
(c / cause
   :ARG0 (c2 / contrast
             :op1 (t / thiết_kế
                     :ARG0 (t2 / tôi)
                     :ARG1 (q / quá_trình)
                     :tense (d / đã))
             :op2 (t3 / thiết_kế
                      :ARG0 t2
                      :ARG1 (h / hình_thể)
                      :polarity -))
   :ARG1 (c3 / có_thể
             :ARG1 (c4 / chạy
                       :ARG0 t2
                       :ARG1 q
                       :frequency (l / lặp_lại
                                     :mod (n / nhiều_lần))
                       :purpose (s / sản_xuất
                                   :ARG0 t2
                                   :ARG1 (h2 / họ
                                             :consist-of (h3 / hình_dạng
                                                             :mod (k / khác_nhau)))))))

