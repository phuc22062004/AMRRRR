# ::id vi_amr_test_000305
# ::snt Kết thúc chuyến đi bơi ở Bắc Cực, Lewis Pugh thề rằng sẽ không thực hiện chuyến đi nào nữa. Nhưng sau khi nghe nói tới hồ Imja ở đỉnh Everest -- 1 hồ nước ở độ cao 5.300 mét, hình thành do hiện tượng băng tan -- anh bắt đầu 1 chuyến hành trình mà qua đó anh học được cách tiếp cận từ căn bản của việc bơi lội và những suy nghĩ về việc khí hậu thay đổi
# ::tok Kết_thúc chuyến đi bơi ở Bắc_Cực , Lewis_Pugh thề rằng sẽ không thực_hiện chuyến đi nào nữa . Nhưng sau khi nghe nói tới hồ Imja ở đỉnh Everest_-- 1 hồ nước ở độ cao 5.300_mét , hình_thành do hiện_tượng băng_tan -- anh bắt_đầu 1 chuyến hành_trình mà qua đó anh học được cách tiếp_cận từ căn_bản của việc bơi_lội và những suy_nghĩ về việc khí_hậu thay_đổi
(m2 / multi-sentence
    :snt1 (t / thề
             :ARG0 (n / người
                      :name (n2 / name
                                :op1 "Lewis"
                                :op2 "Pugh"))
             :ARG1 (t2 / thực_hiện
                       :ARG0 n
                       :ARG1 (c / chuyến_đi
                                :mod (k / khác))
                       :polarity -
                       :tense (s / sẽ))
             :time (k2 / kết_thúc
                       :ARG1 (c2 / chuyến_đi
                                 :mod (b / bơi)
                                 :location (v / vùng_địa_lý
                                              :name (n3 / name
                                                        :op1 "Bắc"
                                                        :op2 "Cực")))))
    :snt2 (b2 / bắt_đầu
              :ARG0 (a / anh)
              :ARG1 (h / hành_trình
                       :ARG0-of (h2 / học
                                    :ARG0 a
                                    :ARG1 (c3 / cách
                                              :manner-of (t3 / tiếp_cận
                                                             :source (c4 / căn_bản)
                                                             :ARG1 (v2 / và
                                                                       :op1 (v3 / việc
                                                                                :mod (b3 / bơi_lội))
                                                                       :op2 (s2 / suy_nghĩ
                                                                                :ARG1 (v4 / việc
                                                                                          :mod (t4 / thay_đổi
                                                                                                   :ARG1 (k3 / khí_hậu)))))))))
              :time (s3 / sau_khi
                        :op1 (n4 / nghe_nói
                                 :ARG0 a
                                 :ARG1 (h3 / hồ
                                           :name (n5 / name
                                                     :op1 "Imja")
                                           :location (d2 / đỉnh
                                                         :name (n6 / name
                                                                   :op1 "Everest"))
                                           :mod (h4 / hồ
                                                    :consist-of (n7 / nước)
                                                    :location (d3 / độ_cao
                                                                  :quant (d / distance-quantity
                                                                            :quant 5300
                                                                            :unit (m / mét)))
                                                    :ARG1-of (h5 / hình_thành
                                                                 :cause (h6 / hiện_tượng
                                                                            :mod (t5 / tan
                                                                                     :ARG1 (b4 / băng))))))))))

# ::id vi_amr_test_000306
# ::snt Nói cách khác, ta thêm 2 năm -- ta gấp ba lần thời gian sống còn lại của chúng, bắt đầu từ điểm ta bắt đầu các trị liệu,
# ::tok Nói cách khác , ta thêm 2 năm -- ta gấp ba lần thời_gian sống_còn lại của chúng , bắt_đầu từ điểm ta bắt_đầu các trị_liệu ,
(c / cause
   :ARG1 (t2 / thêm
             :ARG0 (t3 / ta)
             :ARG1 (t / temporal-quantity
                      :quant 2
                      :unit (n / năm))
             :ARG1-of (m / mean
                         :ARG2 (g / gấp_ba
                                  :ARG0 t3
                                  :ARG1 (t5 / thời_gian
                                            :ARG1 (c2 / chúng)
                                            :ARG1-of (c3 / còn_lại))
                                  :ARG1-of (b / bắt_đầu
                                              :ARG0 t3
                                              :source (d / điểm
                                                         :time-of (b2 / bắt_đầu
                                                                      :ARG0 t3
                                                                      :ARG1 (t4 / trị_liệu)))))))
   :ARG1-of (w / word
               :mod (k / khác)))

