# ::tok Như_vậy , một trong những việc chúng_ta đang làm là dùng sự cải_tạo gen , hoặc liệu_pháp di_truyền , hoặc phương_pháp gây giống có chọn_lọc bình_thường kết_hợp với một_chút kĩ_thuật di_truyền .
(a / and
   :op2 (v / việc
           :quant 1
           :ARG1-of (i / include-91
                       :ARG1 (d / dùng
                                :ARG0 (c / chúng_ta)
                                :ARG1 (h / hoặc
                                         :op1 (c3 / cải_tạo
                                                  :ARG2 (g / gây_giống
                                                           :ARG0-of (c2 / combine
                                                                        :degree (m / một_chút
                                                                                   :mod (s / small))
                                                                        :path (k / kĩ_thuật_di_truyền))
                                                           :ARG1-of (b / bình_thường)
                                                           :mod (c4 / chọn_lọc)))
                                         :op2 (l / liệu_pháp
                                                 :ARG1 g
                                                 :ARG1 k))))
           :ARG1-of (l2 / làm
                        :ARG0 c
                        :tense (d2 / đang))))

