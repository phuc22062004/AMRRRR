                 :ARG2 (t4 / temporal-quantity
                           :quant 1
                           :unit (p / phút))))

# ::id vi_amr_test_000308
# ::snt Tôi nhận ra rằng nếu họ phải ra chiến trường họ sẽ làm những gì chúng tôi đã dạy và sẽ theo lệnh người chỉ huy.
# ::tok Tôi nhận ra rằng nếu họ phải ra chiến_trường họ sẽ làm những gì chúng_tôi đã dạy và sẽ theo lệnh người chỉ_huy .
(n / nhận_ra
   :ARG0 (t / tôi)
   :ARG1 (v / và
            :condition (p / phải
                          :domain (r / ra
                                     :ARG0 (h / họ)
                                     :ARG1 (c / chiến_trường)))
            :op1 (l / làm
                    :ARG0 h
                    :ARG1 (d2 / điều
                              :ARG1-of (d / dạy
                                          :ARG0 (c2 / chúng_tôi)
                                          :ARG2 h
                                          :tense (d3 / đã)))
                    :tense (s / sẽ))
            :op2 (t2 / theo
                     :ARG0 h
                     :ARG1 (l2 / lệnh
                               :poss (n2 / người_chỉ_huy))
                     :tense (s2 / sẽ))))

