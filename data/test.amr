# ::id vi_amr_test_000852
# ::snt Và điều mà ta thấy, tôi nghĩ là một vài chuyển động thay đổi nho nhỏ kết hợp lại có thể sẽ di chuyển được cả một thực thể như là hệ thống nhà tù của chúng ta theo hướng của hi vọng.
# ::tok Và điều mà ta thấy , tôi nghĩ là một_vài chuyển_động thay_đổi nho_nhỏ kết_hợp lại có_thể sẽ di_chuyển được cả một thực_thể như_là hệ_thống nhà_tù của chúng_ta theo hướng của hi_vọng .
(v / và
   :op2 (c2 / cause
            :ARG1 (t / thấy
                     :ARG0 (c / chúng_ta)
                     :ARG1 (c3 / có_thể
                               :ARG1 (d / di_chuyển
                                        :tense (s / sẽ)
                                        :ARG0 (c4 / chuyển_động
                                                  :ARG1 (t2 / thay_đổi)
                                                  :mod (k / kết_hợp)
                                                  :mod (n / nhỏ))
                                        :ARG1 (t3 / thực_thể
                                                  :example (h / hệ_thống
                                                              :mod (n2 / nhà_tù)
                                                              :poss c))
                                        :ARG2 (h2 / hướng
                                                  :mod (h3 / hi_vọng))))
                     :ARG1-of (n3 / nghĩ
                                  :ARG0 (t4 / tôi)))))

