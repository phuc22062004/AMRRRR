# ::id vi_amr_test_000849
# ::snt Hãy tưởng tượng nếu một nhóm các nhà vật lí có thể đứng bên trong một nguyên tử quan sát và nghe động lượng điện từ.
# ::tok Hãy tưởng_tượng nếu một nhóm các nhà_vật_lí có_thể đứng bên trong một nguyên_tử quan_sát và nghe động_lượng điện từ .
(t / tưởng_tượng
   :ARG0 (b / bạn)
   :ARG1 (c / có_thể
            :ARG1 (v / và
                     :op1 (d2 / đứng
                              :ARG1 (n / nhóm
                                       :have-part-91 (n4 / nhà_vật_lí))
                              :ARG2 (b2 / bên_trong
                                        :op1 (n2 / nguyên_tử))
                              :tense (d / đang))
                     :op2 (q / quan_sát
                             :ARG1 (d3 / động_lượng_điện_từ)
                             :tense d)
                     :op3 (n3 / nghe
                              :ARG1 d3
                              :tense d))
            :condition (h / have-condition-91))
   :mode (a / amr-unknown))

# ::id vi_amr_test_000850
# ::snt Cô bé 11 tuổi và cha mẹ em đều qua đời vì bệnh AIDS, đầu tiên là mẹ em và sau đó là cha em.
# ::tok Cô bé 11 tuổi và cha_mẹ em đều qua_đời vì bệnh AIDS , đầu_tiên là mẹ em và sau đó là cha em .
(m2 / multi-sentence
    :snt1 (t / tuổi
             :ARG1 (c / cô)
             :ARG2 (l / lượng-thời_gian
                      :quant 11
                      :unit (n / năm)))
    :snt2 (q / qua_đời
             :ARG1 (n2 / người
                       :ARG0-of (c2 / có-vai-trò-liên-quan-91
                                    :ARG1 c
                                    :ARG1 (c3 / cô)
                                    :ARG2 (c4 / cha_mẹ))
                       :mod (d / đều))
             :ARG1-of (g / gây-ra
                         :ARG0 (b / bệnh
                                  :name (n5 / name
                                            :op1 "AIDS"))))
    :snt3 (v / và
             :op1 (q2 / qua_đời
                      :ARG1 (n3 / người
                                :ARG0-of (c5 / có-vai-trò-liên-quan-91
                                             :ARG1 c3
                                             :ARG2 (m / mẹ))))
             :op2 (q3 / qua_đời
                      :ARG1 (n4 / người
                                :ARG0-of (c6 / có-vai-trò-liên-quan-91
                                             :ARG1 c3
                                             :ARG2 (c7 / cha)))
                      :time (s / sau_đó))))

