                      :ARG1 (p4 / phương_thuốc
                                :ARG1 n2
                                :ARG1-of (h2 / have-degree-91
                                             :ARG2 (t2 / tốt
                                                       :ARG1 p4)
                                             :ARG3 (n4 / nhất))
                                :ARG2 (m3 / mô
                                          :ARG1-of (t / thật)
                                          :mod (s / sinh_học))))
             :ARG2 (h3 / hành_hạ
                       :tense (d4 / đang)
                       :ARG0 (v2 / và
                                 :op1 (b / bệnh
                                         :name (n7 / name
                                                   :op1 "viêm_khớp"))
                                 :op2 (d3 / đau))
                       :ARG1 (b2 / bệnh_nhân
                                 :quant (h4 / hàng
                                            :op1 1000000))))
    :snt2 (d / đưa_ra
             :ARG0 (p3 / person
                       :name (n3 / name
                                 :op1 "Kevin"
                                 :op2 "Stone"))
             :ARG1 (p / phương_pháp
                      :ARG0-of (t3 / tránh
                                   :ARG1 (v3 / và
                                             :op1 (c / chi_phí
                                                     :ARG1-of (c2 / cao))
                                             :op2 (g / giảm
                                                     :ARG1 (c3 / cấy_ghép
                                                               :ARG2 (n5 / người)
                                                               :ARG3 (n6 / người))
