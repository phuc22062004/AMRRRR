# ::id vi_amr_test_000310
# ::snt Gần 2 tỷ người -- vậy là trong 3 người trên trái đất, thì có 1 người cần tới nguồn nước từ Himalayas.
# ::tok Gần 2 tỷ người -- vậy là trong 3 người trên trái_đất , thì có 1 người cần tới nguồn nước từ Himalayas .
(c / cần_tới
   :ARG0 (n / người
            :quant (g / gần
                      :op1 2000000000)
            :ARG1-of (i / include-91
                        :ARG2 (n3 / người
                                  :location (p / planet
                                               :name (n2 / name
                                                         :op1 "Trái_Đất")))
                        :ARG3 (t / thực_thể_phần_trăm
                                 :value "1/3")))
   :ARG1 (n4 / nước
             :source (w / world-region
                        :name (n5 / name
                                  :op1 "Himalayas"))))

# ::id vi_amr_test_000311
# ::snt Chúng tôi lên đường hành quân. nhóm của tôi tiến hành đột kích lúc bình minh-- Bạn biết đấy, kiểu tấn công vào lúc rạng sáng rất kinh điển:chuẩn bị cả đêm, di quân tới điểm xuất kích.
# ::tok Chúng_tôi lên_đường hành_quân . nhóm của tôi tiến_hành đột_kích lúc bình_minh -- Bạn biết đấy , kiểu tấn_công vào lúc rạng sáng rất kinh_điển : chuẩn_bị cả đêm , di_quân tới điểm xuất_kích .
(v / và
   :op1 (h / hành_quân
           :ARG0 (c / chúng_tôi))
   :op2 (d2 / đột_kích
            :ARG0 (n / nhóm
                     :poss (t / tôi))
            :ARG1-of (c2 / có_nghĩa
                         :ARG2 (v2 / và
                                   :op1 (c3 / chuẩn_bị
                                            :ARG0 (b / bạn)
                                            :time (d / date-entity
                                                     :dayperiod (d5 / đêm)
                                                     :mod (c4 / cả)))
                                   :op2 (d3 / di_quân
                                            :ARG0 b
                                            :ARG2 (d6 / điểm_xuất_kích))))
            :mod (k / kinh_điển)
            :time (d4 / date-entity
                      :dayperiod (b2 / bình_minh))))

# ::id vi_amr_test_000312
# ::snt Những người được trở về với cuộc sống là những người có thể hiểu được niềm khao khát là một thuốc có thể cứu chữa bạn khỏi cái chết.
# ::tok Những người được trở về với cuộc_sống là những người có_thể hiểu được niềm khao_khát là một thuốc có_thể cứu_chữa bạn khỏi cái chết .
(n / người
   :ARG0-of (h / hiểu
               :modality (p / possible)
               :modality (d / được)
               :ARG1 (k / khao_khát)
               :ARG2 (t / thuốc
                        :ARG0-of (c / cứu_chữa
                                    :modality (p2 / possible)
                                    :ARG1 (b / bạn)
                                    :source (c2 / chết))))
   :ARG1-of (t2 / trở
                :modality (d2 / được)
                :ARG4 (c3 / cuộc_sống)
                :direction (v / về)))

# ::id vi_amr_test_000313
# ::snt Nhưng lần đầu tiên mà tôi cầm cuốn sách ra khỏi va ly, bé gái tuyệt nhất trong khu lại gần tôi và hỏi &quot; sao bạn lại im lặng như thế ? &quot; -- im lặng, dĩ nhiên rồi, đó là từ hoàn toàn trái ngược với Ồ-N À-O-O
# ::tok Nhưng lần đầu_tiên mà tôi cầm cuốn sách ra khỏi va_ly , bé gái tuyệt_nhất trong khu lại gần tôi và hỏi & quot ; sao bạn lại im_lặng như_thế ? & quot ; -- im_lặng , dĩ_nhiên rồi , đó là từ hoàn_toàn trái_ngược với Ồ-N À-O-O
(c / contrast
   :ARG2 (a / and
            :op1 (l / lại-gần
                    :ARG0 (b / bé_gái
                             :location (k / khu)
                             :ARG1-of (s / score-on-scale
                                         :ARG2 (t2 / tuyệt)
                                         :ARG3 (n / nhất)))
                    :ARG1 (t / tôi)
                    :time (c2 / cầm-ra
                              :ARG0 t
                              :ARG1 (s2 / sách)
                              :ARG2 (v / va_ly
                                       :poss t)
                              :ord (o / ordinal-entity
                                      :value 1)))
            :op2 (h2 / hỏi
                     :ARG0 b
                     :ARG1 (i / im_lặng
                              :domain t
                              :cause (a2 / amr-unknown)
                              :degree (n2 / như-thế)
                              :mod (d / dĩ_nhiên)
                              :ARG1-of (t3 / trái_ngược
                                           :ARG2 (o2 / Ồ-N_À-O-O)
                                           :mod (h / hoàn_toàn))))))

