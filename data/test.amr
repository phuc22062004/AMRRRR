# ::id vi_amr_test_000151
# ::snt Nên tôi đã đề xuất ý tưởng để cải thiện tình hình này sử dụng những ống giấy tái chế này bởi vì chúng rất rẻ và cũng rất chắc, nhưng ngân quỹ của tôi chỉ có 50 đô la cho mỗi lán.
# ::tok Nên tôi đã đề_xuất ý_tưởng để cải_thiện tình_hình này sử_dụng những ống giấy tái_chế này bởi_vì chúng rất rẻ và cũng rất chắc , nhưng ngân_quỹ của tôi chỉ có 50 đô_la cho mỗi lán .
(c / contrast
   :ARG1 (d / đề_xuất
            :tense (d2 / đã)
            :ARG0 (t / tôi)
            :ARG1 (y / ý_tưởng
                     :poss t
                     :topic (c2 / cải_thiện
                                :ARG0 t
                                :ARG1 (t2 / tình_hình
                                          :mod (n / này))
                                :manner (s / sử_dụng
                                           :ARG0 t
                                           :ARG1 (o / ống
                                                    :mod (n2 / này)
                                                    :ARG1-of (t3 / tái_chế)
                                                    :consist-of (g / giấy)))))
            :ARG1-of (c3 / cause
                         :ARG0 (a / and
                                  :op1 (r / rẻ
                                          :domain o
                                          :degree (r2 / rất))
                                  :op2 (c4 / chắc
                                           :domain o
                                           :degree (r3 / rất)
                                           :mod (c5 / cũng)))))
   :ARG2 (c6 / có
             :ARG0 (n3 / ngân_quỹ
                       :poss t)
             :mod (c7 / chỉ)
             :ARG1 (r4 / rate-entity-91
                       :ARG1 (m / monetary-quantity
                                :quant 50
                                :unit (d3 / đô_la
                                          :mod (c8 / country
                                                   :name (n4 / name
                                                             :op1 "U.S."))))
                       :ARG2 (l / lán))))

