    :time (t / trước
             :op1 (b / bây_giờ)
             :quant (n / ngày
                       :quant (v3 / vài)))
    :op1 (x / xếp_hàng
            :ARG0 (t2 / tôi)
            :purpose (c / chờ
                        :ARG1 t2
                        :ARG2 (l / lượt))
            :location (c2 / cửa_hàng
