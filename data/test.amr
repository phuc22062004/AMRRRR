            :tense (d / đang)
            :ARG0 n
            :have-manner-91 (t2 / trên_lưng
                                :op1 (s2 / sư_tử
                                         :poss n))
            :ARG0-of (t / tiến_vào
                        :destination (c3 / chiến_trường))
            :have-purpose-91 (t3 / tiêu_diệt
                                 :ARG0 n
                                 :ARG1 (n3 / người
                                           :have-name-91 (n4 / name
                                                             :op1 "Mahishasur")))))

