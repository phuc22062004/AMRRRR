# ::id vi_amr_test_000858
# ::snt Khiến các em sống trong những vùng này bị bại liệt Và khiến các gia đình Ngày càng nghèo khổ hơn Bởi vì họ đang tìm kiếm một cách vô vọng Và sử dụng những đồng tiền ít ỏi họ kiếm được Cố gắng trong vô ích Tìm cách cứu chữa cho con họ
# ::tok Khiến các em sống trong những vùng này bị bại_liệt Và khiến các gia_đình Ngày_càng nghèo_khổ hơn Bởi_vì họ đang tìm_kiếm một_cách vô_vọng Và sử_dụng những đồng_tiền ít_ỏi họ kiếm được Cố_gắng trong vô_ích Tìm cách cứu_chữa cho con họ
(v / và
   :op1 (k / khiến
           :ARG0 (n / nó)
           :ARG1 (b / bại_liệt
                    :ARG1 (e / em
                             :ARG0-of (s / sống
                                         :location (v2 / vùng
                                                       :mod (n2 / này))))))
   :op2 (k2 / khiến
            :ARG0 (v3 / và
                      :op1 (t / tìm_kiếm
                              :tense (d / đang)
                              :ARG0 (h / họ)
                              :manner (v4 / vô_vọng))
                      :op2 (s2 / sử_dụng
                               :ARG0 h
                               :ARG1 (t2 / tiền
                                         :mod (i / ít_ỏi)
                                         :ARG1-of (k3 / kiếm
                                                      :ARG0 h)))
                      :purpose (c / cố_gắng
                                  :ARG0 h
                                  :ARG1 (t3 / tìm
                                            :ARG0 h
                                            :ARG1 (c2 / cách
                                                      :purpose (c3 / cứu_chữa
                                                                   :ARG0 h
                                                                   :ARG1 (c4 / con
                                                                             :poss h))))
                                  :manner (v5 / vô_ích)))
            :ARG1 (n3 / nghèo_khổ
                      :ARG1 (g / gia_đình)
                      :degree (h2 / hơn
                                  :mod (n4 / ngày_càng)))))

