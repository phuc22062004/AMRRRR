# ::tok Và như_vậy , chỉ đơn_giản là chuyển góc nhìn từ một cái thân cây tới rất nhiều cành con lay_động không ngừng , chúng_ta thấy được rằng cây_cối không đơn_giản là những thực_thể_tĩnh , mà trên thực_tế lại chuyển_động không ngừng .
(v / và
   :op2 (c2 / cause
            :ARG0 (c / chuyển
                     :ARG0 (c3 / chúng_ta)
                     :ARG1 (g / góc_nhìn
                              :poss c3)
                     :source (t / thân_cây
                                :quant 1)
                     :destination (c4 / cành_con
                                      :quant (n / nhiều)
                                      :mod (l / lay_động
                                              :tense (a / amr-unknown)
                                              :manner (n2 / ngừng
                                                          :polarity -)))
                     :ARG1-of (d2 / đơn_giản
                                  :mod (c7 / chỉ)))
            :ARG1 (p / possible
                     :domain (t2 / thấy
                                 :ARG0 c3
                                 :ARG1 (v2 / và
                                           :op1 (t3 / thực_thể
                                                    :domain (c5 / cây_cối)
                                                    :mod (t4 / tĩnh)
                                                    :ARG1-of (d / đơn_giản
                                                                :polarity -))
                                           :op2 (c6 / chuyển_động
                                                    :tense a
                                                    :domain c5
                                                    :mod (t5 / thực_tế)
                                                    :manner (n3 / ngừng
                                                                :polarity -)))))))

