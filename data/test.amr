                       :ARG2 (a / and
                                :op1 (p2 / phát_hiện
                                         :ARG1 (o / ô_nhiễm
                                                  :location (d / đất))
                                         :ARG2 (m / môi_trường))
                                :op2 (u2 / ứng_dụng
                                         :ARG2 (h / hải_quan))
                                :op3 (p3 / phát_hiện
                                         :ARG0 (c / cục_thuế)
                                         :ARG1 (h2 / hàng_hoá
                                                   :location (t2 / thùng_chứa)
                                                   :mod (b2 / bất_hợp_pháp
                                                            :polarity -)))
                                :op4 (v / vân_vân))))
   :polarity amr-unknown)

