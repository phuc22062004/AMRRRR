# ::id vi_amr_test_000625
# ::snt Vào tháng 8 năm 2008, các cán bộ cộng đồng của UAE đã ghi nhận 40 % của 1,098 trại lao động ở nước này đã vi phạm các quy định tối thiểu về an toàn sức khoẻ và PCCH.
# ::tok Vào tháng 8 năm 2008 , các cán_bộ cộng_đồng của UAE đã ghi_nhận 40 % của 1,098_trại lao_động ở nước này đã vi_phạm các quy_định tối_thiểu về an_toàn sức khỏe và PCCH .
(g / ghi_nhận
   :tense (d2 / đã)
   :ARG0 (n2 / người
             :ARG0-of (h / have-org-role-91
                         :ARG1 (q / quốc_gia
                                  :name (n / name
                                           :op1 "UAE"))
                         :ARG2 (c / cán_bộ
                                  :mod (c2 / cộng_đồng))))
   :ARG1 (v / vi_phạm
            :tense (d3 / đã)
            :ARG0 (p / percentage-entity
                     :value 40
                     :quant-of (t / trại
                                  :quant 1098
                                  :mod (l / lao_động)
                                  :location q))
            :ARG1 (q2 / quy_định
                      :mod (t2 / tối_thiểu)
                      :topic (a2 / and
                                 :op1 (a / an_toàn
                                         :ARG1 (s / sức_khoẻ))
                                 :op2 (p2 / PCCH))))
   :time (d / date-entity
            :month 8
            :year 2008))

