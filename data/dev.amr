# ::id vi_amr_dev_000940
# ::snt Năm 2010 tại Haiti, đã xảy ra một trận động đất lớn, nhưng không thể bay đến đó được, nên tôi đã đến Santo Domigo, đất nước kế bên, ngồi xe sáu giờ đồng hồ đến Haiti cùng những sinh viên địa phương ở Santo Domingo xây dựng 50 chỗ trú ẩn bằng những ống giấy ở địa phương.
# ::tok Năm 2010 tại Haiti , đã xảy ra một trận động_đất lớn , nhưng không_thể bay đến đó được , nên tôi đã đến Santo_Domigo , đất_nước kế bên , ngồi xe sáu giờ đồng_hồ đến Haiti cùng những sinh_viên địa_phương ở Santo_Domingo xây_dựng 50 chỗ trú_ẩn bằng những ống giấy ở địa_phương .
(c / contrast
   :ARG1 (d2 / động_đất
             :mod (l / lớn)
             :location (q / quốc_gia
                          :name (n / name
                                   :op1 "Haiti"))
             :time (d / date-entity
                      :year 2010)
             :tense (d4 / đã))
   :ARG2 (c2 / cause
             :ARG0 (p / possible
                      :domain (b / bay
                                 :ARG0 (t / tôi)
                                 :destination q)
                      :polarity -)
             :ARG1 (d5 / đến
                       :ARG0 t
                       :destination (q2 / quốc_gia
                                        :name (n2 / name
                                                  :op1 "Santo"
                                                  :op2 "Domingo")
                                        :mod (k / kế_bên))
                       :tense (d6 / đã)
                       :purpose (d7 / đến
                                    :ARG0 t
                                    :destination q
                                    :manner (n3 / ngồi
                                                :ARG1 (x / xe)
                                                :duration (d3 / duration
                                                              :quant 6
                                                              :unit (g / giờ)))
                                    :purpose (x2 / xây_dựng
                                                 :ARG0 (a / and
                                                          :op1 t
                                                          :op2 (s / sinh_viên
                                                                  :mod (d8 / địa_phương)
                                                                  :location q2))
                                                 :ARG1 (c3 / chỗ_trú_ẩn
                                                           :quant 50)
                                                 :instrument (o / ống
                                                                :consist-of (g2 / giấy)
                                                                :mod (d9 / địa_phương)))))))

