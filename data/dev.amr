# ::tok Thậm_chí nếu một tên khủng_bố có được 72 cô gái trinh sau khi chết , trong kiếp này , tính_cách của anh ta -- tính_cách đáng tiếc thay của anh ta -- là thành_quả của bộ_não của ảnh .
(t / thành_quả
   :tense (d / đang)
   :ARG0 (b / bộ_não
            :poss (n / người
                     :mod (k / khủng_bố
                             :mod (t2 / tự_sát))))
   :ARG1 (t3 / tính_cách
             :poss n
             :mod (d2 / đáng_tiếc
                      :degree (t4 / thay)))
   :concession (h / have-concession-91
                  :ARG1 t
                  :ARG2 (c / có_được
                           :tense (s / sẽ)
                           :ARG0 n
                           :ARG1 (c2 / cô_gái_trinh
                                     :quant 72)
                           :time (s2 / sau_khi_chết)))
   :time (k2 / kiếp
             :mod (n2 / này)))

